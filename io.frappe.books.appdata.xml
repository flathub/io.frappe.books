<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.frappe.books</id>

  <name>Frappe Books</name>
  <summary>Accounting and bookkeeping for small businesses</summary>

  <metadata_license>FSFAP</metadata_license>
  <project_license>AGPL-3.0-only</project_license>
  <content_rating type="oars-1.1" />
  <supports>
    <control>pointing</control>
    <control>keyboard</control>
    <control>touch</control>
  </supports>

  <description>
    <p>
      Frappe Books is a double-entry accounting application designed for small businesses
      and freelancers. It covers the full bookkeeping workflow: invoicing, bills, payments,
      journal entries, and financial reports all in a clean, modern interface.
    </p>
    <p>Key features:</p>
    <ul>
      <li>Create and send GST-ready sales invoices and purchase bills</li>
      <li>Track income, expenses, assets, and liabilities with a full chart of accounts</li>
      <li>Reconcile bank statements and manage payments</li>
      <li>Run Profit and Loss, Balance Sheet, Trial Balance, and General Ledger reports</li>
      <li>Support for multiple currencies and tax schemes</li>
      <li>Point-of-sale (POS) mode for retail transactions</li>
      <li>Customisable print templates for invoices and other documents</li>
      <li>Data stored locally in a SQLite file, no account or internet connection required</li>
    </ul>
  </description>

  <launchable type="desktop-id">io.frappe.books.desktop</launchable>

